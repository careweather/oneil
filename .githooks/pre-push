#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Determine whether any commit being pushed touches a Rust file.
# stdin lines: <local_ref> <local_sha> <remote_ref> <remote_sha>
# A zero remote sha means a new branch with no upstream yet.
ZERO="0000000000000000000000000000000000000000"
HAS_RUST=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
    if [[ "$remote_sha" == "$ZERO" ]]; then
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi
    if git diff --name-only "$range" | grep -q '\.rs$'; then
        HAS_RUST=1
        break
    fi
done

if [[ "$HAS_RUST" == "0" ]]; then
    exit 0
fi

echo "» Running fmt..."
cargo fmt

echo "» Running clippy..."
RUSTFLAGS="--deny warnings" cargo clippy --all-targets --all-features

echo "» Running tests..."
RUSTFLAGS="--deny warnings" cargo test --all-features --verbose
