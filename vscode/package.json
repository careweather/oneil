{
  "name": "oneil",
  "displayName": "Oneil",
  "description": "VS Code support for the Oneil design specification language",
  "icon": "./icons/oneil-logo-large.png",
  "version": "0.2.2",
  "publisher": "careweather",
  "license": "MPL-2.0",
  "engines": {
    "vscode": "^1.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "bugs": {
    "url": "https://github.com/careweather/oneil/issues"
  },
  "homepage": "https://github.com/careweather/oneil",
  "repository": {
    "type": "git",
    "url": "https://github.com/careweather/oneil.git"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "oneil.restartLanguageServer",
        "title": "Oneil: Restart Language Server",
        "icon": "$(debug-restart)"
      },
      {
        "command": "oneil.openRenderedView",
        "title": "Oneil: Open Rendered View",
        "icon": "$(open-preview)"
      },
      {
        "command": "oneil.reloadRenderedView",
        "title": "Oneil: Reload Rendered View",
        "icon": "$(refresh)"
      },
      {
        "command": "oneil.pdf.toggleOfflineMode",
        "title": "Oneil: Toggle PDF Offline Mode",
        "icon": "$(cloud)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "oneil.openRenderedView",
          "when": "resourceLangId == oneil",
          "group": "navigation"
        },
        {
          "command": "oneil.restartLanguageServer",
          "when": "resourceLangId == oneil",
          "group": "navigation"
        },
        {
          "command": "oneil.reloadRenderedView",
          "when": "activeWebviewPanelId == oneilRenderedView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Oneil",
      "properties": {
        "oneil.serverPath": {
          "type": "string",
          "default": null,
          "description": "Path to the Oneil language server executable. Use this when the server is not on PATH. Leave empty to use ONEIL_PATH env var or \"oneil\"."
        },
        "oneil.cacheReadPolicy": {
          "type": "string",
          "default": "always",
          "description": "When to read from the Python call cache.",
          "enum": [
            "always",
            "prompt",
            "never"
          ]
        },
        "oneil.cacheWritePolicy": {
          "type": "string",
          "default": "always",
          "description": "When to write to the Python call cache.",
          "enum": [
            "always",
            "prompt",
            "never"
          ]
        },
        "oneil.pdf.cacheDir": {
          "type": "string",
          "default": "",
          "description": "Directory where citation PDFs are cached. Supports ~ expansion. Defaults to ~/.local/oneil/resources."
        },
        "oneil.pdf.autoDownload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically download citation PDFs to the local cache when opened (no prompt). If false, you are asked each time."
        },
        "oneil.pdf.offlineOnly": {
          "type": "boolean",
          "default": false,
          "description": "Offline mode: only open PDFs that are already in the local cache. Remote URLs will not be followed. Toggle via the status bar or the 'Oneil: Toggle PDF Offline Mode' command."
        }
      }
    },
    "languages": [
      {
        "id": "oneil",
        "aliases": [
          "Oneil",
          "oneil"
        ],
        "extensions": [
          ".on",
          ".one"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/oneil-logo.svg",
          "dark": "./icons/oneil-logo.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "oneil",
        "scopeName": "source.oneil",
        "path": "./syntaxes/oneil.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.latex": "latex",
          "meta.embedded.markdown": "markdown"
        },
        "tokenTypes": {
          "meta.embedded.latex": "other"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "npm --prefix model-renderer run build",
    "watch:webview": "npm --prefix model-renderer run watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}