{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Oneil",
  "scopeName": "source.oneil",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#metadata"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "comment": "hash comments",
          "name": "comment.line.number-sign.oneil",
          "begin": "#",
          "end": "$",
          "patterns": [
            {
              "comment": "comment tags",
              "name": "keyword.other.commenttag.oneil",
              "match": "\\b(TODO|NOTE|FIXME|BUG|OPTIMIZE|HACK|XXX)\\b"
            }
          ]
        },
        {
          "comment": "single-line notes (Markdown with LaTeX math and Oneil placeholders)",
          "name": "comment.line.documentation.oneil",
          "begin": "^\\s*~(?!~~)",
          "end": "$",
          "patterns": [
            {
              "include": "#note-placeholder"
            },
            {
              "include": "#note-math"
            },
            {
              "include": "#note-markdown-inline"
            }
          ]
        },
        {
          "comment": "multi-line notes (Markdown with LaTeX math and Oneil placeholders)",
          "name": "comment.block.documentation.oneil",
          "begin": "^\\s*~~~[~]*\\s*$",
          "end": "^\\s*~~~[~]*\\s*$",
          "patterns": [
            {
              "include": "#note-placeholder"
            },
            {
              "include": "#note-math"
            },
            {
              "include": "#note-markdown-inline"
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "import declaration",
          "begin": "^(\\s*)(import)(\\s+)([A-Za-z_][A-Za-z0-9_]*)(?=#|$)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            },
            "4": {
              "name": "variable.other.oneil"
            }
          },
          "end": "(?=#)|$"
        },
        {
          "comment": "submodel declaration",
          "begin": "^(\\s*)(submodel)(\\s+)([A-Za-z_][A-Za-z0-9_/]*)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            },
            "4": {
              "name": "entity.name.type.oneil"
            }
          },
          "end": "(?=#)|$",
          "patterns": [
            {
              "name": "keyword.control.oneil",
              "match": "\\bas\\b"
            },
            {
              "begin": "\\[",
              "end": "\\]",
              "patterns": [
                {
                  "name": "keyword.control.oneil",
                  "match": "\\bas\\b"
                }
              ]
            }
          ]
        },
        {
          "comment": "reference declaration",
          "begin": "^(\\s*)(reference)(\\s+)([A-Za-z_][A-Za-z0-9_/]*)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            },
            "4": {
              "name": "entity.name.type.oneil"
            }
          },
          "end": "(?=#)|$",
          "patterns": [
            {
              "name": "keyword.control.oneil",
              "match": "\\bas\\b"
            }
          ]
        },
        {
          "comment": "design declaration",
          "begin": "^(\\s*)(design)(\\s+)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            }
          },
          "end": "(?=#)|$"
        },
        {
          "comment": "apply declaration",
          "begin": "^(\\s*)(apply)(\\s+)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            }
          },
          "end": "(?=#)|$",
          "patterns": [
            {
              "name": "keyword.control.oneil",
              "match": "\\bto\\b"
            },
            {
              "begin": "\\[",
              "end": "\\]",
              "patterns": [
                {
                  "name": "keyword.control.oneil",
                  "match": "\\bto\\b"
                }
              ]
            }
          ]
        },
        {
          "comment": "section declaration",
          "begin": "^(\\s*)(section)(\\s+)([^()\\[\\]{#~:= \\t\\n*$][^()\\[\\]#:=\\n]*)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            },
            "4": {
              "name": "entity.name.section.oneil"
            }
          },
          "end": "(?=#)|$"
        },
        {
          "comment": "test declaration",
          "begin": "^(\\s*)(test)(\\s*:)",
          "beginCaptures": {
            "2": {
              "name": "keyword.control.oneil"
            }
          },
          "end": "(?=#)|$",
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        },
        {
          "comment": "parameter definition (name[.model] =), handles both parameter definitions and design overrides",
          "begin": "([A-Za-z_][A-Za-z0-9_]*)(?:\\.([A-Za-z_][A-Za-z0-9_]*))?\\s*=(?!=)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.variable.oneil"
            },
            "2": {
              "name": "variable.other.oneil"
            }
          },
          "end": "(?=#)|$",
          "patterns": [
            {
              "name": "keyword.control.oneil",
              "match": "\\bif\\b"
            },
            {
              "include": "#expression"
            }
          ]
        },
        {
          "comment": "render name (LaTeX symbol) after parameter colon, e.g. {\\hat{v}}. The begin lookahead requires a balanced closing } on the same line, so piecewise { branches (which never close on the same line) fall through to the piecewise pattern.",
          "begin": "\\{(?=[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\})",
          "end": "\\}",
          "name": "string.other.render-name.oneil",
          "contentName": "meta.embedded.latex",
          "patterns": [
            {
              "include": "text.tex.latex"
            }
          ]
        },
        {
          "comment": "piecewise branch",
          "begin": "\\{",
          "end": "(?=#)|$",
          "patterns": [
            {
              "name": "keyword.control.oneil",
              "match": "\\bif\\b"
            },
            {
              "include": "#expression"
            }
          ]
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "comment": "parameter metadata (label, limits); must stay after declarations in root order",
          "begin": "^\\s*((\\$|\\*\\*?)?)\\s*([^()\\[\\]{#~:= \\t\\n*$][^()\\[\\]#:=\\n]*)\\s*",
          "beginCaptures": {
            "3": {
              "name": "entity.name.tag.oneil"
            }
          },
          "end": ":\\s*",
          "patterns": [
            {
              "begin": "\\(",
              "end": "\\)\\s*",
              "patterns": [
                {
                  "include": "#expression"
                }
              ]
            },
            {
              "begin": "\\[",
              "end": "\\]\\s*",
              "patterns": [
                {
                  "include": "#expression"
                }
              ]
            }
          ]
        }
      ]
    },
    "expression": {
      "patterns": [
        {
          "include": "#expr-literals"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#external-ref"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#function-invoke"
        },
        {
          "include": "#unit-cast"
        },
        {
          "include": "#identifiers"
        }
      ]
    },
    "expr-literals": {
      "patterns": [
        {
          "name": "constant.language.oneil",
          "match": "\\b(true|false|inf)\\b"
        },
        {
          "name": "keyword.operator.word.oneil",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.oneil",
          "match": "\\b(\\d+(\\.\\d*)?|\\.\\d+)([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.oneil",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.oneil",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.oneil",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "external-ref": {
      "patterns": [
        {
          "comment": "external parameter reference: in foo.bar, foo is the parameter (variable.other) and bar is the submodel alias (entity.name.type)",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\.([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.oneil"
            },
            "2": {
              "name": "entity.name.type.oneil"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.oneil",
          "match": "--|//|<=|>=|==|!="
        },
        {
          "name": "keyword.operator.oneil",
          "match": "[+\\-*/%^?<>|]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "plain identifier usage in an expression (fallback after all more-specific patterns)",
          "name": "variable.other.oneil",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "function-invoke": {
      "patterns": [
        {
          "comment": "identifier followed by (",
          "name": "entity.name.function.oneil",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "unit-cast": {
      "patterns": [
        {
          "comment": "unit after : until ) or end of line",
          "begin": ":",
          "end": "(?=\\)|$)",
          "patterns": [
            {
              "name": "entity.name.type.oneil",
              "match": "[A-Za-z_][A-Za-z0-9_]*(?:\\^[+-]?[0-9]+)?(?:\\s*[*/]\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\^[+-]?[0-9]+)?)*"
            }
          ]
        }
      ]
    },
    "note-placeholder": {
      "comment": "Oneil-specific parameter interpolation inside note regions: {{var:equation}} renders the parameter expression as KaTeX, {{var:value}} renders the evaluated numeric value. Listed before note-markdown-inline in each note's patterns so it takes priority.",
      "patterns": [
        {
          "comment": "parameter interpolation {{var:equation}} / {{var:value}}",
          "name": "meta.interpolation.oneil",
          "match": "\\{\\{(\\w+):(equation|value)\\}\\}",
          "captures": {
            "1": {
              "name": "variable.other.oneil"
            },
            "2": {
              "name": "keyword.other.oneil"
            }
          }
        }
      ]
    },
    "note-markdown-inline": {
      "comment": "Explicit Markdown patterns for note regions. We do NOT embed text.html.markdown because (a) it contains ~~~ fenced-code-block patterns that conflict with our own ~~~ note delimiters, and (b) it treats lines indented 4+ spaces as indented code blocks, which breaks notes whose content is uniformly indented in source. All patterns here are indentation-agnostic (leading \\s* absorbed or irrelevant). Ordered from most- to least-specific to avoid partial matches.",
      "patterns": [
        {
          "comment": "ATX heading # … ###### — works at any indentation",
          "match": "^\\s*(#{1,6})\\s+(.+?)(?:\\s+#+)?\\s*$",
          "captures": {
            "1": { "name": "punctuation.definition.heading.markdown" },
            "2": { "name": "markup.heading.markdown" }
          }
        },
        {
          "comment": "block quote > ...",
          "match": "^\\s*(>+)\\s*",
          "captures": {
            "1": { "name": "punctuation.definition.quote.markdown" }
          }
        },
        {
          "comment": "unordered list item  - / * / +",
          "match": "^(\\s*)([-*+])(?=\\s)",
          "captures": {
            "2": { "name": "punctuation.definition.list.markdown" }
          }
        },
        {
          "comment": "ordered list item  1. / 2.",
          "match": "^(\\s*)(\\d+\\.)(\\s)",
          "captures": {
            "2": { "name": "punctuation.definition.list.markdown" }
          }
        },
        {
          "comment": "bold+italic ***...***",
          "name": "markup.bold.italic.markdown",
          "match": "\\*{3}[^*\\n]+\\*{3}"
        },
        {
          "comment": "bold **...**",
          "name": "markup.bold.markdown",
          "match": "\\*\\*[^*\\n]+\\*\\*"
        },
        {
          "comment": "italic *...*  (not part of ** or ***)",
          "name": "markup.italic.markdown",
          "match": "(?<!\\*)\\*(?!\\*)[^*\\n]+\\*(?!\\*)"
        },
        {
          "comment": "strikethrough ~~text~~ (double tilde, not triple)",
          "name": "markup.strikethrough.markdown",
          "match": "~~(?!~)[^~\\n]+~~"
        },
        {
          "comment": "inline code `...`",
          "name": "markup.inline.raw.string.markdown",
          "begin": "`",
          "end": "`"
        },
        {
          "comment": "image ![alt](url)",
          "name": "meta.image.inline.markdown",
          "match": "!\\[([^\\]]+)\\]\\(([^)\\s]+)[^)]*\\)",
          "captures": {
            "1": { "name": "string.other.link.description.markdown" },
            "2": { "name": "markup.underline.link.image.markdown" }
          }
        },
        {
          "comment": "link [text](url)",
          "name": "meta.link.inline.markdown",
          "match": "\\[([^\\]]+)\\]\\(([^)\\s]+)[^)]*\\)",
          "captures": {
            "1": { "name": "string.other.link.title.markdown" },
            "2": { "name": "markup.underline.link.markdown" }
          }
        }
      ]
    },
    "note-math": {
      "comment": "LaTeX math inside notes. text.html.markdown does not guarantee $...$ highlighting, so we inject explicit patterns that embed text.tex.latex. $$ display math must come first so it is not consumed as two inline $ spans.",
      "patterns": [
        {
          "comment": "LaTeX display math $$...$$",
          "begin": "\\$\\$",
          "end": "\\$\\$",
          "name": "markup.math.block.markdown",
          "contentName": "meta.embedded.latex",
          "patterns": [
            {
              "include": "text.tex.latex"
            }
          ]
        },
        {
          "comment": "LaTeX inline math $...$  (negative lookahead avoids matching the first $ of $$)",
          "begin": "\\$(?!\\$)",
          "end": "\\$",
          "name": "markup.math.inline.markdown",
          "contentName": "meta.embedded.latex",
          "patterns": [
            {
              "include": "text.tex.latex"
            }
          ]
        }
      ]
    }
  }
}